[PATHS]
input_dir = G:\QQMusic\Download
output_dir = G:\QQMusic\Decrypted

[LOGGING]
log_level = INFO
log_file = logs/decrypt.log
save_stats = true

[OPTIONS]
preserve_structure = true
skip_existing = true
max_retries = 3
retry_delay = 2
verify_metadata = true

[NOTIFICATIONS]
show_completion = true
show_summary = true
